<!-- PROCESS -->
<section class="section process-section">
    <div class="section__inner">
        <div class="section__tag">Our Process</div>
        <h2 class="section__title">From Idea to Move-In</h2>
        <div class="process__steps">
            <div class="process-step">
                <div class="process-step__num">01</div>
                <div class="process-step__line"></div>
                <h4>Book Consultation</h4>
                <p>Meet our designer at your home for a free site visit and discussion.</p>
            </div>
            <div class="process-step">
                <div class="process-step__num">02</div>
                <div class="process-step__line"></div>
                <h4>Design &amp; 3D Preview</h4>
                <p>Get photorealistic renders and a detailed quote before committing.</p>
            </div>
            <div class="process-step">
                <div class="process-step__num">03</div>
                <div class="process-step__line"></div>
                <h4>Execution Begins</h4>
                <p>Our project managers handle everything — material, labour and quality checks.</p>
            </div>
            <div class="process-step">
                <div class="process-step__num">04</div>
                <h4>Move In &amp; Enjoy</h4>
                <p>Handover with a thorough walkthrough and 10-year warranty documentation.</p>
            </div>
        </div>
    </div>
</section>

