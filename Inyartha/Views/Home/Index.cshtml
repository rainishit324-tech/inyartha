@{
    ViewData["Title"] = "Home";
}

<!-- HERO -->
<section class="hero">
    <div class="hero__bg">
        <img src="/images/hero.jpg" alt="Beautiful home interior" class="hero__bg-img" />
        <div class="hero__overlay"></div>
    </div>
    <div class="hero__content">
        <p class="hero__tag">Bengaluru's Premier Interior Studio</p>
        <h1 class="hero__title">Transform Your Home<br />Into a <em>Dream Space</em></h1>
        <p class="hero__sub">End-to-end interior design — from concept to completion. Transparent pricing, quality materials, on-time delivery.</p>
        <div class="hero__actions">
            <a href="#pricing" class="btn btn--gold btn--lg">Get Free Estimate</a>
            <a href="#projects" class="btn btn--ghost btn--lg">View Our Work</a>
        </div>
        <div class="hero__trust">
            <div class="trust-item"><strong>200+</strong><span>Projects Done</span></div>
            <div class="trust-divider"></div>
            <div class="trust-item"><strong>8+</strong><span>Years Experience</span></div>
            <div class="trust-divider"></div>
            <div class="trust-item"><strong>100%</strong><span>Satisfaction</span></div>
        </div>
    </div>
</section>

<!-- PRICING CARDS -->
<section class="section pricing-section" id="pricing">
    <div class="section__inner">
        <div class="section__tag">Transparent Pricing</div>
        <h2 class="section__title">Know Your Budget Upfront</h2>
        <p class="section__sub">No hidden costs. Every rupee accounted for before work begins.</p>
        <div class="pricing__grid">
            <div class="pricing-card">
                <div class="pricing-card__icon">🏠</div>
                <h3>2 BHK</h3>
                <div class="pricing-card__price">Starting at <strong>Rs. 3.57L</strong></div>
                <ul class="pricing-card__list">
                    <li>Modular Kitchen</li>
                    <li>2 Bedrooms with Wardrobes</li>
                    <li>Living &amp; Dining Area</li>
                    <li>False Ceiling &amp; Lighting</li>
                </ul>
                <a href="#contact" class="btn btn--gold">Get Quote</a>
            </div>
            <div class="pricing-card pricing-card--featured">
                <div class="pricing-card__badge">Most Popular</div>
                <div class="pricing-card__icon">🏡</div>
                <h3>3 BHK</h3>
                <div class="pricing-card__price">Starting at <strong>Rs. 4.23L</strong></div>
                <ul class="pricing-card__list">
                    <li>Modular Kitchen</li>
                    <li>3 Bedrooms with Wardrobes</li>
                    <li>Living &amp; Dining Area</li>
                    <li>False Ceiling &amp; Lighting</li>
                    <li>Pooja &amp; Storage Units</li>
                </ul>
                <a href="#contact" class="btn btn--gold">Get Quote</a>
            </div>
            <div class="pricing-card">
                <div class="pricing-card__icon">🏘️</div>
                <h3>4 BHK &amp; Villa</h3>
                <div class="pricing-card__price">Starting at <strong>Rs. 4.81L</strong></div>
                <ul class="pricing-card__list">
                    <li>Modular Kitchen</li>
                    <li>4+ Bedrooms with Wardrobes</li>
                    <li>All Common Areas</li>
                    <li>Premium Finishes</li>
                </ul>
                <a href="#contact" class="btn btn--gold">Get Quote</a>
            </div>
        </div>
        <div class="pricing__rooms">
            <div class="room-card">
                <span>🍳</span>
                <div><strong>Modular Kitchen</strong><small>Starting at Rs. 1.37L</small></div>
            </div>
            <div class="room-card">
                <span>🛏️</span>
                <div><strong>Bedroom</strong><small>Starting at Rs. 1.49L</small></div>
            </div>
            <div class="room-card">
                <span>🛋️</span>
                <div><strong>Living Room</strong><small>Starting at Rs. 1.2L</small></div>
            </div>
        </div>
    </div>
</section>

<!-- WHY INYARTHA -->
<section class="section why-section" id="about">
    <div class="section__inner why__inner">
        <div class="why__text">
            <div class="section__tag">Why Inyartha</div>
            <h2 class="section__title">Designed Around<br />Your Life</h2>
            <p class="why__desc">We don't just design spaces — we design experiences. Every project at Inyartha starts with understanding how you live, cook, sleep and entertain.</p>
            <div class="why__features">
                <div class="why__feature">
                    <div class="why__feature-icon">🛡️</div>
                    <div><strong>10-Year Warranty</strong><p>Industry-best warranty on all modular work</p></div>
                </div>
                <div class="why__feature">
                    <div class="why__feature-icon">💰</div>
                    <div><strong>Transparent Pricing</strong><p>Every cost explained before execution begins</p></div>
                </div>
                <div class="why__feature">
                    <div class="why__feature-icon">📐</div>
                    <div><strong>3D Visualisation</strong><p>See your home before we build it</p></div>
                </div>
                <div class="why__feature">
                    <div class="why__feature-icon">⏱️</div>
                    <div><strong>On-Time Delivery</strong><p>We commit to timelines and honour them</p></div>
                </div>
            </div>
            <a href="#contact" class="btn btn--gold" style="margin-top:8px;">Book Free Consultation</a>
        </div>
        <div class="why__image-stack">
            <img src="/images/why-main.jpg" alt="Modern living room" class="why__img why__img--main" />
            <img src="/images/why-overlay.jpg" alt="Luxury bedroom" class="why__img why__img--overlay" />
        </div>
    </div>
</section>

