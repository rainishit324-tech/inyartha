<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Inyartha Design Studio</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="nav" aria-label="Primary">
        <a href="/" class="nav__brand">
            <img src="~/images/logo.png" alt="Inyartha Logo" class="nav__logo"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='inline-grid';" />
            <span class="mark" style="display:none">I</span>
            <span>Inyartha</span>
        </a>
        <div class="nav__links">
            <a href="/#about">About</a>
            <a href="/#services">Services</a>
            <a href="/#projects">Projects</a>
            <a href="/#testimonials">Testimonials</a>
            <a href="/#contact">Contact</a>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a href="/Quote" class="btn btn--gold">Quotes Dashboard</a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn" style="cursor:pointer;border:none;">Logout</button>
                </form>
            }
            else
            {
                <a href="/#contact" class="btn btn--gold">Get Free Quote</a>
                <a href="/Account/Login" class="btn">Admin</a>
            }
        </div>
        <button class="nav__toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
    </nav>

    <aside class="mobile-menu" id="mobileMenu">
        <a href="/#about">About</a>
        <a href="/#services">Services</a>
        <a href="/#projects">Projects</a>
        <a href="/#testimonials">Testimonials</a>
        <a href="/#contact">Contact</a>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a href="/Quote" class="btn btn--gold">Quotes</a>
        }
        else
        {
            <a href="/#contact" class="btn btn--gold">Get Free Quote</a>
        }
    </aside>

    <main>@RenderBody()</main>

    <footer class="footer" id="contact">
        <div class="footer__grid">
            <div class="footer__brand">
                <img src="~/images/logo.png" alt="Inyartha" class="footer__logo"
                     onerror="this.style.display='none';this.nextElementSibling.style.display='inline-grid';" />
                <span class="mark" style="display:none;width:44px;height:44px;font-size:1.2rem;
                margin-bottom:14px;border-radius:50%;
                background:linear-gradient(135deg,var(--gold),var(--gold-deep));
                color:#fff;font-family:'Cormorant Garamond',serif;font-weight:700;place-items:center;">I</span>
                <h3>Inyartha</h3>
                <p>Bengaluru's premier interior design studio — crafting spaces that balance beauty and function.</p>
            </div>
            <div class="footer__col">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/">Home</a></li>
                    <li><a href="/#about">About</a></li>
                    <li><a href="/#services">Services</a></li>
                    <li><a href="/#projects">Projects</a></li>
                    <li><a href="/#testimonials">Testimonials</a></li>
                    <li><a href="/#contact">Contact</a></li>
                </ul>
            </div>
            <div class="footer__col">
                <h4>Contact</h4>
                <ul>
                    <li><a href="tel:+918123297276">081232 97276</a></li>
                    <li><a href="mailto:hello@inyartha.com">hello@inyartha.com</a></li>
                    <li><p>1st Floor, Om City, Budigere Cross,<br />Konadasapura, Bengaluru 560049</p></li>
                </ul>
            </div>
        </div>
        <div class="footer__bottom">
            &copy; @DateTime.Now.Year Inyartha Design Studio. All rights reserved.
        </div>
    </footer>

    <a href="#" class="to-top" id="toTop" aria-label="Back to top">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 19V5M5 12l7-7 7 7" />
        </svg>
    </a>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>